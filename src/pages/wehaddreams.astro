---
import PageLayout from "../layouts/PageLayout.astro";
import Screenshot from "../components/Screenshot.astro";
import weHadDreamsImage from '../images/wehaddreams.png';
import ScreenshotsBlock from "../components/ScreenshotsBlock.astro";
import Button from "../components/Button.astro";
import ImageLink from "../components/ImageLink.astro";

const url = 'https://wehaddreams.com'
---

<PageLayout
  title="We Had Dreams"
  description="I made an animated tribute to the voices of Palestinians living under bombardment."
>
  <Fragment slot="links">
    <Button>
      <a href={url} target="_blank">
        View Tribute
      </a>
    </Button>
  </Fragment>
  <ScreenshotsBlock>
    <div class="col-span-4">
      <a class="tab-focus" href={url}>
        <ImageLink
          href={weHadDreamsImage.src}
        >
        <Screenshot
            image={weHadDreamsImage}
            alt="Graphic showing a nightime city skyline with explosions and the text: We Had Dreams, Palestinians living and dying under seige"
          />
        </ImageLink>
      </a>
    </div>
  </ScreenshotsBlock>
</PageLayout>