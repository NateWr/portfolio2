---
import '../styles/global.css';
import ContactLink from '../components/ContactLink.astro';
import Fonts from '../components/Fonts.astro'
import leftArrowIcon from "../images/left-arrow-icon.svg?raw";
import HalftoneImageCaption from '../components/HalftoneImageCaption.astro';
import UnderlineText from '../components/UnderlineText.astro';

interface Props {
	title: string;
	description?: string;
	nav: {href: string, text: string, isHome?: boolean}[];
	revealNav?: boolean;
}

const { title, description, nav, revealNav = false } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta property="og:title" content={title}>
		{description && (
			<meta name="description" content={description}>
			<meta name="og:description" content={description}>
			<meta name="twitter:description" content={description}>
		)}
		<meta property="og:image" content="https://notthisway.com/opengraph.png">
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630">
		<meta property="twitter:image" content="https://notthisway.com/opengraph.png">
		<meta property="twitter:card" content="summary_large_image">
		<Fonts />
		<!-- Matomo -->
		<script>
			// @ts-nocheck
			var _paq = window._paq = window._paq || [];
			/* tracker methods like "setCustomDimension" should be called before "trackPageView" */
			_paq.push(['trackPageView']);
			_paq.push(['enableLinkTracking']);
			(function() {
			var u="https://matomo.notthisway.com/";
			_paq.push(['setTrackerUrl', u+'matomo.php']);
			_paq.push(['setSiteId', '1']);
			var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
			g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
			})();
		</script>
		<!-- End Matomo Code -->
	</head>
	<body>
		<slot name="header-image" />
		<header
			id="nav"
			class="
				fixed
				top-4
				left-2/4
				z-50
				bg-white
				border-2
				border-black
				px-4
				py-3
				font-mono
				font-bold
				uppercase
				text-sm
				leading-none
				whitespace-nowrap
				-translate-x-1/2
				transition-all
				duration-300
				sm-landscape:top-2
				sm-landscape:text-xs
				sm-landscape:leading-none
				sm-landscape:py-2
			"
			style={revealNav ? `
				--transform: translate(-50%, -4rem);
				transform: var(--transform);
			` : ''}
		>
			<nav>
				<ul
					class="
						flex
						items-center
						gap-6
					"
				>
					{nav.map((item) => (
						<li>
							<a
								href={item.href}
								class="
									tab-focus
									flex
									items-center
									gap-4
									transition-transform
									hover:scale-110
								"
							>
								{item?.isHome && (
									<span class="w-6 flex" set:html={leftArrowIcon} />
								)}
								{item.text}
							</a>
						</li>
					))}
				</ul>
			</nav>
			<div
				id="progress"
				class="
					absolute
					left-0
					bottom-0
					bg-blue
					h-1
					transition-all
					duration-300
				"
				style="
					--width: 0%;
					width: var(--width);
				"
			></div>
		</header>
		<main>
			<slot />
		</main>
		<footer
			class="
				relative
				overflow-hidden
				pb-[120vw]
			"
		>
			<figure
				class="
					absolute
					bottom-0
					right-0
					w-[200vw]
					h-[200vw]
					translate-x-1/4
					-z-50
				"
				aria-hidden="true"
			>
				<canvas
					class="
						absolute
						top-0
						left-0
						w-full
						h-full
						-z-10
						bg-white
					"
					aria-hidden="true"
					data-halftone-image="colorado.png"
					data-halftone-mask="mask-bottom-1.png"
				/>
				<figcaption
					class="
						absolute
						right-[50vw]
						top-3/5
						bg-white
						font-mono
						font-bold
						text-xs
					"
				>
					<HalftoneImageCaption
						text="Cache la Poudre River, Colorado"
					/>
				</figcaption>
			</figure>
			<h2 class="sr-only">Contact</h2>
			<div
				id="contact"
				class="
					mt-[25vh]
					flex
					flex-col
					items-center
					gap-6
					text-center
					text-balance
					xs:text-xl
				"
			>
				<p class="
					mx-auto
					max-w-[280px]
					text-2xl
					font-bold
					leading-normal
					xs:text-3xl
					xs:max-w-sm
				">
					<UnderlineText>Ready for a chat?</UnderlineText>
				</p>
				<p class="mt-4">
					Get in touch if you think I can help you with something.
				</p>
				<p class="flex flex-col gap-2 font-semibold">
					<a href="mailto:natew+work@notthisway.com">
						natew+work@notthisway.com
					</a>
					<a href="https://github.com/NateWr">
						github.com/NateWr
					</a>
				</p>
			</div>
		</footer>
		<script src="../scripts/index.ts"></script>
	</body>
</html>
