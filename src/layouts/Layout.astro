---
import '../styles/global.css';
import Fonts from '../components/Fonts.astro'
import HalftoneImageCaption from '../components/HalftoneImageCaption.astro';
import NavBar from '../components/NavBar.astro';
import UnderlineText from '../components/UnderlineText.astro';

interface Props {
	title: string;
	description?: string;
	nav: {href: string, text: string, isHome?: boolean}[];
}

const { title, description, nav } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-pt-32">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta property="og:title" content={title}>
		{description && (
			<meta name="description" content={description}>
			<meta name="og:description" content={description}>
			<meta name="twitter:description" content={description}>
		)}
		<meta property="og:image" content="https://notthisway.com/opengraph.jpg">
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630">
		<meta property="twitter:image" content="https://notthisway.com/opengraph.jpg">
		<meta property="twitter:card" content="summary_large_image">
		<link rel="icon" href="/site-icon-32.png" type="image/png">
		<link rel="apple-touch-icon" href="/site-icon-180.png">
		<link rel="manifest" href="/manifest.webmanifest">
		<Fonts />
		<!-- Matomo -->
		<script>
			// @ts-nocheck
			var _paq = window._paq = window._paq || [];
			/* tracker methods like "setCustomDimension" should be called before "trackPageView" */
			_paq.push(['trackPageView']);
			_paq.push(['enableLinkTracking']);
			(function() {
			var u="https://matomo.notthisway.com/";
			_paq.push(['setTrackerUrl', u+'matomo.php']);
			_paq.push(['setSiteId', '1']);
			var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
			g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
			})();
		</script>
		<!-- End Matomo Code -->
	</head>
	<body>
		<slot name="header-image" />
		<header
			id="nav"
			class="
				fixed
				top-4
				left-1/2
				z-50
				-translate-x-1/2
				-translate-y-20
				transition-all
				duration-300
				lg:left-auto
				lg:right-4
				lg:translate-x-0
				lg:translate-y-0
				3xl:right-6
				3xl:top-6
			"
		>
			<NavBar nav={nav} />
		</header>
		<main>
			<slot />
		</main>
		<footer
			class="
				relative
				overflow-hidden
				pb-[120vw]
				sm:pb-[60vw]
			"
		>
			<figure
				class="
					absolute
					bottom-0
					right-0
					w-[200vw]
					h-[200vw]
					translate-x-1/4
					-z-50
					sm:w-screen
					sm:h-[100vw]
					sm:translate-x-0
				"
				aria-hidden="true"
			>
				<canvas
					class="
						absolute
						top-0
						left-0
						w-full
						h-full
						-z-10
						bg-white
					"
					aria-hidden="true"
					data-halftone-image="colorado.jpg"
					data-halftone-mask="mask-bottom-1.png"
				/>
				<figcaption
					class="
						absolute
						right-[50vw]
						top-3/5
						bg-white
						font-mono
						font-bold
						text-xs
						sm:right-0
					"
				>
					<HalftoneImageCaption
						text="Cache la Poudre River, Colorado"
					/>
				</figcaption>
			</figure>
			<h2 class="sr-only">Contact</h2>
			<div
				id="contact"
				class="
					pt-[25vh]
					flex
					flex-col
					items-center
					gap-6
					text-center
					text-balance
					xs:text-xl
					sm:pt-64
					2xl:pt-96
					4xl:pt-128
					4xl:text-2xl
				"
			>
				<p class="
					mx-auto
					max-w-[280px]
					text-2xl
					font-bold
					leading-normal
					xs:text-3xl
					xs:max-w-sm
					4xl:text-5xl
				">
					<UnderlineText classes="inline-block">Ready for a chat?</UnderlineText>
				</p>
				<p class="mt-4 max-w-sm">
					Get in touch if you think I can help you with something.
				</p>
				<p class="flex flex-col gap-2 font-semibold">
					<a href="mailto:natew+work@notthisway.com" class="tab-focus">
						natew+work@notthisway.com
					</a>
					<a href="https://github.com/NateWr" class="tab-focus" target="_blank">
						github.com/NateWr
					</a>
				</p>
			</div>
		</footer>
		<div id="lightbox" class="fixed -z-50 scale-0 opacity-0 top-0 left-0 w-screen h-screen cursor-pointer flex justify-center items-center bg-black text-white transition-all duration-500">
			<button class="w-12 h-12 absolute top-0 right-0 cursor-pointer">
				<span class="sr-only">Close</span>
				<svg class="w-full h-full" width="192" height="192" viewBox="0 0 192 192" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M162 77.5003C163.5 42.5003 121.5 26.0003 99.5 26.5003C78 26.5003 46 56 36.5 74C27 92 36.5 122.5 41.5 132.5C46.5 142.5 61.5 160 84 165C106.5 170 136.5 146.5 146 132.5C155.5 118.5 160.5 112.5 162 77.5003Z" fill="black"/>
					<path d="M137.173 62.4825L126.322 51.7942C114.174 63.8545 101.718 78.573 97.1237 83.4279C92.5297 88.2828 63.8863 126.716 62.4064 127.891C60.9265 129.066 64.1322 136.173 63.9779 137.503C63.8237 138.832 75.6003 141.545 76.926 141.699C78.2517 141.853 93.1132 117.985 96.3815 112.976C99.6498 107.967 124.562 78.5302 126.042 77.3549C127.226 76.4147 127.728 74.4075 127.831 73.5214L137.173 62.4825Z" fill="white"/>
					<path d="M66.5697 58.0654L57.9399 68.1862C76.3954 84.3545 95.0462 104.464 102.392 111.42C109.737 118.375 107.293 118.183 106.73 119.121C106.168 120.058 123.12 136.6 123.499 138.102C123.878 139.604 132.898 137.366 134.023 135.491C135.147 133.616 133.449 130.047 133.632 127.608C133.815 125.169 101.977 90.7753 94.2528 82.3181C86.5285 73.8609 72.5952 62.9543 72.0329 63.8917C71.5831 64.6417 68.2033 60.32 66.5697 58.0654Z" fill="white"/>
				</svg>
			</button>
		</div>
		<script src="../scripts/index.ts"></script>
	</body>
</html>
