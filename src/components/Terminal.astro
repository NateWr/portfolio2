---
import type { Terminal } from '../scripts/terminal'

interface Props {
  item: Terminal;
  classes?: string;
}

const { item, classes = '' } = Astro.props
---

<a
  class={`
    flex
    flex-col
    bg-white
    overflow-hidden
    outline-4
    outline-white
    rounded
    group
    transition-colors
    transition-150
    hover:outline-yellow
    focus-visible:outline-yellow
    ${classes}
  `}
  href={item.url}
  data-blur="true"
>
  <div
    class="
      flex
      px-3
      py-2
      gap-0.5
      bg-code-teal-very-dark
      transition-colors
      transition-150
      group-hover:bg-yellow
      group-focus-visible:bg-yellow
      4xl:px-4
      4xl:py-3
    "
  >
    <div class="w-2 h-2 rounded-full bg-code-dark-grey"></div>
    <div class="w-2 h-2 rounded-full bg-code-dark-grey"></div>
    <div class="w-2 h-2 rounded-full bg-code-dark-grey"></div>
  </div>
  <div
    class="
      px-2
      py-4
      flex
      flex-col
      gap-6
      grow
      font-mono
      bg-code-teal-dark
      text-white/[0.85]
      transition-colors
      transition-150
      group-hover:bg-code-teal-very-dark
      group-focus-visible:bg-code-teal-very-dark
      sm:px-4
      sm:py-6
    "
  >
    <div
      class="
        text-xs
        font-bold
        max-w-full
        overflow-hidden
        text-nowrap
        xl:text-sm
        4xl:text-base
      "
    >
      <span class="text-code-teal">{item.path}</span>
      <span class="text-code-grey">on</span>
      <span class="text-code-fuscia">{item.branch}</span>
      <span class="text-code-dark-grey">{item.commit}</span>
    </div>
    <div
      class="
        text-lg
        font-bold
        md:text-lg
        3xl:text-xl
        4xl:text-2xl
      "
    >
      # {item.title}
    </div>
    <div
      class="
        4xl:text-lg
      "
    >
      {item.description}
    </div>
    <div class="
      mt-auto
      font-bold
      text-yellow
      sm:text-lg
    ">
      [ Learn More ]
    </div>
  </div>
</div>

<style>
  [data-blur] {
    transition: all 0.5s;
    transform-origin: center;
    filter: blur(0);
    transform: scale(1);
    opacity: 1;
  }

  [data-blur="true"] {
    filter: blur(10px);
    transform: scale(0.8);
    opacity: 0;
  }

  @media (min-width: 1536px) {
    [data-blur] {
      transition: none;
      opacity: 1;
      filter: blur(0);
      transform: scale(1);
    }
  }
</style>