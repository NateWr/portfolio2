---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image?: ImageMetadata;
  alt?: string;
}

const { image = null, alt = '' } = Astro.props;
---

<div
  class="
    p-1
    border-2
    border-black
    bg-white
    overflow-hidden
  "
>
  {image ? (
    <Picture
      alt={alt}
      src={image}
      widths={[340, 680, 840, 1200, 1800]}
      quality={80}
      class="
        bg-black
      "
    />
  ) : (
    <slot />
  )}
</div>
