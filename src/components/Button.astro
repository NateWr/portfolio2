---
import buttonSvg from "../images/button.svg?raw";
import underlineSvg from "../images/underline.svg?raw";
---

<span class="button font-mono font-extrabold uppercase">
  <span class="button-border" set:html={buttonSvg} />
  <span class="button-underline" set:html={underlineSvg} />
  <slot />
</span>

<style>
  .button {
    position: relative;
    display: inline-block;
  }
  .button :global(a),
  .button :global(button) {
    display: inline-flex;
    padding: 0.75em 1.5em;
  }
  .button-border :global(svg),
  .button-underline :global(svg) {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
    z-index: -1;
  }
  .button-border :global(.bg path) {
    fill: white;
  }
  .button-underline :global(svg) {
    width: calc(100% - 1.5em);
    height: 0.75em;
    top: auto;
    bottom: 0.25em;
  }
  .button-underline :global(path) {
    fill: var(--color-yellow);
  }
  .button:hover,
  .button:focus-within {
    color: white;
  }
  .button :global(a:focus-visible),
  .button :global(button:focus-visible) {
    outline: none;
  }
  .button:hover :global(.button-border path),
  .button:focus-within :global(.button-border path) {
    fill: black;
  }
</style>