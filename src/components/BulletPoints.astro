---
import IconBulletPoint from './IconBulletPoint.astro';

interface Props {
  items: string[];
}

const { items } = Astro.props
---

<ul class="
  flex
  gap-4
  items-center
  font-mono
  font-bold
  uppercase
  text-xs
  xs:gap-6
  sm:text-sm
  sm:gap-8
">
  {items.map((item, i) => (
    <li class="
      flex
      gap-1
      items-center
      sm:gap-2
    ">
      <IconBulletPoint classes={`w-3 h-3 ${i ? 'rotate-' + i * 50 : ''}`} />
      <Fragment set:html={item} />
    </li>
  ))}
</ul>