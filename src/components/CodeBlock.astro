---
import { Code } from 'astro:components';
import type {
	BuiltinLanguage,
} from 'shiki';

interface Props {
  code: string;
  lang?: BuiltinLanguage;
}

const { code, lang = 'txt' } = Astro.props
---

<figure
  class="
    w-full
    max-w-4xl
    bg-code-teal-very-dark
    text-white
    text-sm
    rounded-[12px]
    md:text-lg
    3xl:max-w-5xl
  "
>
  {Astro.slots.has('default') && (
    <figcaption
      class="
        font-medium
        bg-white
        border-2
        border-black
        text-black
        rounded-t-[10px]
        p-4
        leading-tight
      "
    >
      <slot />
    </figcaption>
  )}
  <Code
    code={code}
    lang={lang}
    theme="ayu-dark"
    class={`
      p-6
      rounded-b-[12px]
      ${!Astro.slots.has('default') ? 'rounded-t-[12px]' : ''}
      xl:p-6
    `}
  />
</figure>